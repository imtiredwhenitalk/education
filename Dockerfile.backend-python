FROM python:3.12-slim

WORKDIR /app

COPY backend_py/requirements.txt ./backend_py/requirements.txt
RUN pip install --no-cache-dir -r backend_py/requirements.txt

COPY backend_py ./backend_py
COPY backend_py/data ./backend_py/data

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "backend_py.app.main:app", "--host", "0.0.0.0", "--port", "8000"]
